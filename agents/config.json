    "sequentialWorkflow": {
      "phases": [
        "1. Product Owner defines requirements and user stories.",
        "2. System Architect designs APIs and logical database ERDs.",
        "3. Database Administrator translates designs to Prisma schema migrations.",
        "4. Frontend Lead scaffolds modules and state interfaces.",
        "5. Backend Lead scaffolds controllers and route handlers.",
        "6. UI/UX Designer builds theme properties and CSS style tokens.",
        "7. Security Specialist audits routes and authentication configuration.",
        "8. QA Engineer writes test blueprints and configures linting schemas.",
        "9. DevOps Engineer wraps services in Docker containerization and Dokploy files.",
        "10. Orchestrator executes final validation and merge checks."
      ]
    },
    "parallelWorkflow": {
      "description": "After DBA migrates models, Backend, Frontend, and UI/UX scaffold features concurrently. Security audits backend changes while QA schedules frontend validation tests.",
      "allowedParallelTracks": [
        ["backend_lead", "security_specialist"],
        ["frontend_lead", "ui_ux_accessibility"],
        ["qa_engineer", "devops_engineer"]
      ]
    },
    "moduleWorkflow": {
      "steps": [
        "1. PO writes feature backlog user stories.",
        "2. Architect generates OpenAPI contract.",
        "3. DBA updates Prisma model configurations.",
        "4. Developers scaffold the mock integration layouts.",
        "5. QA maps testing scenarios.",
        "6. Orchestrator validates feature completeness."
      ]
    },
    "sprintWorkflow": {
      "schedule": "2-week cycles",
      "milestones": {
        "planning": "Days 1-2 (PO requirements + Architect designs)",
        "development": "Days 3-7 (DBA migrations + Dev configurations + UI/UX styles)",
        "hardening": "Days 8-9 (Security audits + QA tests + DevOps containers)",
        "release": "Day 10 (Orchestrator reviews, approves, and packages release)"
      }
    },
    "noCodeConstraint": "Do not execute or build final application codebase. Only write configuration files, documentation, scaffolding templates, and agent assets."
